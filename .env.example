# ── Repository Configuration ──────────────────
# Path to the Terraform repository this agent manages
TERRAFORM_REPO_PATH=/path/to/your/terraform/repo

# ── AI Configuration ─────────────────────────
# Anthropic API Key for Claude AI
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-20250514

# Enable Claude AI (set to true)
USE_CLAUDE=true

# ── Server Configuration ─────────────────────
# Port for the API server (used for Open WebUI integration)
PORT=8001

# ── Git Configuration ────────────────────────
# Git user name for commits
GIT_USER_NAME=Terraform Agent
GIT_USER_EMAIL=agent@example.com

# ── Logging ──────────────────────────────────
LOG_FILE=agent.log
LOG_LEVEL=INFO
